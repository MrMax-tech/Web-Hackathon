{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer", "delivery_boy"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Support ticket",
      "type": "object",
      "properties": {
        "ticketNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["order", "payment"] },
        "status": { "type": "string", "enum": ["pending", "in-progress", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "customerId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "details": { "type": "object" },
        "messages": { "type": "array" }
      },
      "required": ["ticketNumber", "type", "status", "customerId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets"
    }
  }
}
